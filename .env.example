# =============================================================================
# teLLMe — Environment Configuration
# =============================================================================
# Copy to .env and adjust values:  cp .env.example .env

# ── LLM ─────────────────────────────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5-coder:7b
LITELLM_MODEL=ollama/qwen2.5-coder:7b
LITELLM_API_BASE=http://ollama:11434
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── NLP2CMD ─────────────────────────────────────────────────────────────────
NLP2CMD_PORT=8000
NLP2CMD_LOG_LEVEL=info
NLP2CMD_AUTO_EXECUTE=false

# ── Toonic ──────────────────────────────────────────────────────────────────
TOONIC_PORT=8900
TOONIC_LOG_LEVEL=INFO
LLM_MODEL=ollama/qwen2.5-coder:7b

# ── Gateway ─────────────────────────────────────────────────────────────────
GATEWAY_PORT=9000
GATEWAY_LOG_LEVEL=info

# ── Workspace (mounted into containers) ─────────────────────────────────────
WORKSPACE_DIR=./workspace
